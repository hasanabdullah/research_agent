# LLM Provider: "gemini", "vertex", "anthropic", "openrouter", or "openai"
LLM_PROVIDER=gemini

# Option A: Gemini API Key (get from https://aistudio.google.com/apikey)
# LLM_API_KEY=AIzaSy...

# Option B: Vertex AI (uses gcloud auth, no API key needed)
# LLM_PROVIDER=vertex
# VERTEX_PROJECT=my-gcp-project-id
# VERTEX_LOCATION=us-central1
# Requires: gcloud auth application-default login

# Optional: Notion integration
# Preferred: set these in config.yaml under the "notion:" section instead.
# NOTION_TOKEN=
# NOTION_PAGE_ID=
