# Model name — OpenRouter format works with any provider;
# resolve_model() auto-converts for Anthropic/OpenAI when needed.
model: anthropic/claude-opus-4.6

# research = auto-approve research files, refuse code edits
# full = human approves everything (code + research)
mode: research

budget:
  max_per_day_usd: 10.00
  max_total_usd: 10.00

# Cost per 1M tokens (adjust for your provider)
pricing:
  input_per_mtok: 5.00
  output_per_mtok: 25.00

protected_files:
  - CONSTITUTION.md
  - MISSION.md
  - .env
  - .gitignore
  - config.yaml

# Code files — only modifiable in 'full' mode
modifiable_files:
  - agent.py
  - tools.py
  - supervisor.py
  - costs.py
  - tests/test_agent.py
  - data/identity.json

# Agent can create/edit any .md or .txt file under this directory
research_dir: data/research

active_topic: ""

# Notion integration — set via dashboard Configure tab
notion:
  token: ""
  root_page_id: ""
  hub_database_id: ""

# LLM provider & API key — set via dashboard Configure tab
# Valid providers: openrouter, anthropic, openai, gemini
llm:
  provider: ""
  api_key: ""
